<Window x:Class="CodeStormHackathon.Views.BulkUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="UC 3.2 — Smart Updater (Bulk Updates)" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Actualizare Administrativă în Masă (Bulk Update)" FontSize="20" FontWeight="Bold" Foreground="#4338CA" Margin="0,0,0,15"/>

        <GroupBox Grid.Row="1" Header="Configurare Variabile" Style="{StaticResource MaterialDesignCardGroupBox}" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" Grid.Column="0" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="Text de căutat (ex: Decan Prof. Ionescu)"/>
                <materialDesign:PackIcon Kind="ArrowRightThick" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#64748B"/>
                <TextBox x:Name="TxtReplace" Grid.Column="2" Style="{StaticResource MaterialDesignFloatingHintTextBox}" materialDesign:HintAssist.Hint="Text nou (ex: Decan Prof. Popescu)"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="Documente Selectate (Review)" Style="{StaticResource MaterialDesignCardGroupBox}">
            <DockPanel>
                <Button x:Name="BtnAddFiles" Content="Adaugă Fișiere (.docx)" DockPanel.Dock="Top" Margin="0,0,0,10" Click="BtnAddFiles_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                <ListBox x:Name="FileList" BorderBrush="#E2E8F0" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding StatusColor}" FontStyle="Italic" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </GroupBox>

        <Button x:Name="BtnApplyAll" Grid.Row="3" Content="APPLY TO ALL" Height="45" Margin="0,15,0,0" Click="BtnApplyAll_Click"
                Style="{StaticResource MaterialDesignRaisedButton}" Background="#10B981" BorderBrush="#10B981" Foreground="White" FontWeight="Bold"/>
    </Grid>
</Window>