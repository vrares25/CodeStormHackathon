<Window x:Class="CodeStormHackathon.Views.DiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="UC 1.3 — Syllabus Diff (Comparație Fișe Disciplină)"
        Height="750" Width="1200" MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="13"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Selectează documentele pentru comparație"
                  Style="{StaticResource MaterialDesignCardGroupBox}"
                  materialDesign:ColorZoneAssist.Mode="PrimaryLight"
                  Margin="0,0,0,12">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="📄 FD Versiune Veche (Referință)" FontWeight="SemiBold"
                               Foreground="#EF4444" Margin="0,0,0,6"/>
                    <DockPanel Background="Transparent" AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropOld">
                        <Button x:Name="BtnBrowseOld" Content="Caută..." Click="BtnBrowseOld_Click"
            DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                        <TextBox x:Name="TxtOldPath" IsReadOnly="True"
             Style="{StaticResource MaterialDesignOutlinedTextBox}"
             materialDesign:HintAssist.Hint="FD din anul precedent..."/>
                    </DockPanel>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="→" FontSize="28"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                           Margin="0,0,0,8" Foreground="#6366F1"/>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="📄 FD Versiune Nouă (Target)" FontWeight="SemiBold"
                               Foreground="#10B981" Margin="0,0,0,6"/>
                    <DockPanel Background="Transparent" AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropNew">
                        <Button x:Name="BtnBrowseNew" Content="Caută..." Click="BtnBrowseNew_Click"
            DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                        <TextBox x:Name="TxtNewPath" IsReadOnly="True"
             Style="{StaticResource MaterialDesignOutlinedTextBox}"
             materialDesign:HintAssist.Hint="FD nouă sau template completat..."/>
                    </DockPanel>
                </StackPanel>

                <Button Grid.Column="3" x:Name="BtnRunDiff"
                        Content="▶  Analizează Diferențele"
                        Click="BtnRunDiff_Click"
                        Margin="16,0,0,0" Height="40" Padding="16,0"
                        VerticalAlignment="Bottom"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#6366F1" BorderBrush="#6366F1" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="6"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="ChkOnlyChanges" Content="Arată doar modificările" 
                      FontWeight="Bold" Foreground="#4338CA" Margin="0,0,20,0"
                      Checked="ChkOnlyChanges_CheckedChanged" Unchecked="ChkOnlyChanges_CheckedChanged"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="0,0,15,0"/>

            <TextBlock Text="Legendă: " FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <Border Background="#FEE2E2" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                <TextBlock Text="🔴 Modificat / Eliminat" Foreground="#EF4444" FontSize="12"/>
            </Border>
            <Border Background="#DCFCE7" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                <TextBlock Text="🟢 Adăugat / Nou" Foreground="#16A34A" FontSize="12"/>
            </Border>
            <Border Background="#F1F5F9" CornerRadius="4" Padding="8,3">
                <TextBlock Text="⬜ Neschimbat" Foreground="#64748B" FontSize="12"/>
            </Border>

            <ProgressBar x:Name="DiffSpinner"
                         Style="{StaticResource MaterialDesignCircularProgressBar}"
                         IsIndeterminate="True" Visibility="Collapsed"
                         Width="20" Height="20" Margin="20,0,8,0"/>
            <TextBlock x:Name="StatusInfoText" Text="" VerticalAlignment="Center"
                       Foreground="#6366F1" FontStyle="Italic"/>
        </StackPanel>

        <Border Grid.Row="2" x:Name="SummaryBorder" Visibility="Collapsed"
                Background="#EEF2FF" BorderBrush="#6366F1" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel>
                    <materialDesign:PackIcon Kind="AutoFix" Foreground="#4338CA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtDiffStats" FontWeight="Bold" Foreground="#4338CA" VerticalAlignment="Center"/>
                </DockPanel>

                <Expander HorizontalAlignment="Stretch" Margin="0,4,0,0">
                    <Expander.Header>
                        <TextBlock Text="Vezi analiza narativă completă (AI)" FontSize="12" FontStyle="Italic" Foreground="#6366F1"/>
                    </Expander.Header>
                    <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="SummaryText" 
                                   TextWrapping="Wrap" 
                                   Padding="0,8,0,0" 
                                   Foreground="#1E293B" 
                                   LineHeight="20"/>
                    </ScrollViewer>
                </Expander>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Style="{StaticResource MaterialDesignCardGroupBox}">
                <GroupBox.Header>
                    <TextBlock FontWeight="Bold" Foreground="#EF4444">📄 Versiune VECHE</TextBlock>
                </GroupBox.Header>
                <ScrollViewer x:Name="OldScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="OldPanel" Margin="8"/>
                </ScrollViewer>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <GroupBox Grid.Column="2" Style="{StaticResource MaterialDesignCardGroupBox}">
                <GroupBox.Header>
                    <TextBlock FontWeight="Bold" Foreground="#10B981">📄 Versiune NOUĂ</TextBlock>
                </GroupBox.Header>
                <ScrollViewer x:Name="NewScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="NewPanel" Margin="8"/>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</Window>