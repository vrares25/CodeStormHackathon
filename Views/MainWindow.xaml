<Window x:Class="SistemAcademic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Sistem Inteligent Management Academic - v2.0" Height="750" Width="1050"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Configurare Surse Date" Margin="0,0,0,20" 
                  Style="{StaticResource MaterialDesignCardGroupBox}"
                  materialDesign:ColorZoneAssist.Mode="PrimaryLight">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Plan de Învățământ (Source of Truth)" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowsePlan" Content="Caută..." Click="BtnBrowsePlan_Click" DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                            <TextBox x:Name="TxtPlanPath" IsReadOnly="True" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Trage fișierul plan_invatamant.pdf aici..."
                                     AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropPlan"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fișa Disciplinei (Document de analizat)" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowseFD" Content="Caută..." Click="BtnBrowseFD_Click" DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                            <TextBox x:Name="TxtFDPath" IsReadOnly="True" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Trage fisa_disciplina.docx aici..."
                                     AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropFD"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock Text="Metodă Citire:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                    <RadioButton x:Name="RadioPdfParser" Content="Parser Direct (PDF/Word)" IsChecked="True" Margin="0,0,20,0" Style="{StaticResource MaterialDesignUserForegroundRadioButton}"/>
                    <RadioButton x:Name="RadioAiVision" Content="AI Vision (Scanări/Poze)" Style="{StaticResource MaterialDesignUserForegroundRadioButton}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Columns="2" Grid.Row="0" Margin="0,0,0,15">
                    <Button x:Name="BtnFastCheck" Click="BtnFastCheck_Click" Margin="0,0,10,0" Height="45" Style="{StaticResource MaterialDesignOutlinedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LightningBolt" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Verificare Rapidă" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnAiAnalysis" Click="BtnAiAnalysis_Click" Margin="10,0,0,0" Height="45" Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Brain" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Analiză Avansată AI" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <GroupBox Header="Raport de Integritate și Conformitate" Grid.Row="1" Style="{StaticResource MaterialDesignCardGroupBox}" Margin="0,0,0,15">
                    <ListBox x:Name="ErrorsListBox" Style="{StaticResource MaterialDesignListBox}"/>
                </GroupBox>

                <Button x:Name="BtnExportSyllabus" Grid.Row="2" Click="BtnExportSyllabus_Click" Height="50" 
                        Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="#10B981" BorderBrush="#10B981" Foreground="White"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocumentArrowRight" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Migrare pe Template Nou (2026)" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <GroupBox Grid.Column="2" Header="AI Copilot Asistent" Style="{StaticResource MaterialDesignCardGroupBox}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <StackPanel x:Name="ChatDisplay" Margin="5">
                            <Border Padding="12,10" Margin="0,0,0,10" MaxWidth="260" HorizontalAlignment="Left" 
                                    Background="#E5E7EB" CornerRadius="15,15,15,2">
                                <TextBlock Text="Salut! Sunt pregătit să te ajut. Încarcă documentele pentru context sau întreabă-mă ceva direct." 
                                           TextWrapping="Wrap" Foreground="#1F2937"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ChatInput" Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 materialDesign:HintAssist.Hint="Scrie o cerință..." TextWrapping="Wrap" MaxHeight="80" VerticalScrollBarVisibility="Auto"/>
                        <Button x:Name="BtnSendCopilot" Grid.Column="1" Click="BtnSendCopilot_Click" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Margin="10,0,0,0" VerticalAlignment="Bottom">
                            <materialDesign:PackIcon Kind="Send" Width="20" Height="20"/>
                        </Button>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="InformationOutline" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <ProgressBar x:Name="LoadingSpinner" Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Visibility="Collapsed" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Pregătit pentru procesare."/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:Chip Content="Local: Llama 3.2 Vision" Margin="0,0,10,0"/>
                    <materialDesign:Chip Content="Cloud: Gemma 3 27B" Background="{DynamicResource PrimaryHueLightBrush}" Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>