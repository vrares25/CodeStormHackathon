<Window x:Class="CodeStormHackathon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Sistem Inteligent Management Academic - v2.0" Height="750" Width="1050"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Configurare Surse Date" Margin="0,0,0,20" 
                  Style="{StaticResource MaterialDesignCardGroupBox}"
                  materialDesign:ColorZoneAssist.Mode="PrimaryLight">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Plan de Învățământ (Source of Truth)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowsePlan" Content="Caută..." Click="BtnBrowsePlan_Click" DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                            <TextBox x:Name="TxtPlanPath" IsReadOnly="True" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Trage fișierul plan.pdf aici..."
                                     AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropPlan"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Fișa Disciplinei (Document de analizat)" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowseFD" Content="Caută..." Click="BtnBrowseFD_Click" DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                            <TextBox x:Name="TxtFDPath" IsReadOnly="True" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                     materialDesign:HintAssist.Hint="Trage fisele.pdf/docx aici..."
                                     AllowDrop="True" PreviewDragOver="FileDragOver" PreviewDrop="FileDropFD"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <TextBlock Text="Metodă Citire:" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="SemiBold"/>
                    <RadioButton x:Name="RadioPdfParser" Content="Digital (Text)" IsChecked="True" Margin="0,0,20,0" Style="{StaticResource MaterialDesignUserForegroundRadioButton}"/>
                    <RadioButton x:Name="RadioAiVision" Content="Vision (Scanări/Poze)" Style="{StaticResource MaterialDesignUserForegroundRadioButton}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnAiAnalysis" Grid.Row="0" Click="BtnAiAnalysis_Click" Margin="0,0,0,15" Height="55" 
                        Style="{StaticResource MaterialDesignRaisedButton}" materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#6366F1" BorderBrush="#6366F1" Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Brain" Width="26" Height="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="EXECUTE AI ACADEMIC AUDIT" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    </StackPanel>
                </Button>

                <GroupBox Header="Raport de Integritate și Conformitate" Grid.Row="1" Style="{StaticResource MaterialDesignCardGroupBox}" Margin="0,0,0,15">
                    <ListBox x:Name="ErrorsListBox" Style="{StaticResource MaterialDesignListBox}"/>
                </GroupBox>

                <StackPanel Grid.Row="2" Margin="0,0,0,0">
                    <Button x:Name="BtnExportSyllabus" Click="BtnExportSyllabus_Click" Height="50"
                                                       Style="{StaticResource MaterialDesignRaisedButton}"
                                                       Background="#10B981" BorderBrush="#10B981" Foreground="White"
                                                       materialDesign:ButtonAssist.CornerRadius="8"
                                                       Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocumentArrowRight" Width="24" Height="24"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Migrare pe Template Nou (2026)" FontSize="15"
                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- ★ BUTON NOU: Syllabus Diff ★ -->
                    <Button x:Name="BtnOpenDiff" Click="BtnOpenDiff_Click" Height="50"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#F59E0B" BorderBrush="#F59E0B" Foreground="White"
                            materialDesign:ButtonAssist.CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Compare" Width="24" Height="24"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Syllabus Diff (Comparație Versiuni)" FontSize="15"
                                       FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <GroupBox Grid.Column="2" Header="AI Copilot Asistent" Style="{StaticResource MaterialDesignCardGroupBox}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                        <StackPanel x:Name="ChatDisplay" Margin="5"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ChatInput" Grid.Column="0" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 materialDesign:HintAssist.Hint="Scrie o cerință..." TextWrapping="Wrap" MaxHeight="80" VerticalScrollBarVisibility="Auto"/>
                        <Button x:Name="BtnSendCopilot" Grid.Column="1" Click="BtnSendCopilot_Click" Style="{StaticResource MaterialDesignFloatingActionMiniButton}" Margin="10,0,0,0" VerticalAlignment="Bottom">
                            <materialDesign:PackIcon Kind="Send" Width="20" Height="20"/>
                        </Button>
                    </Grid>
                </Grid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2" Background="Transparent" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar x:Name="LoadingSpinner" Style="{StaticResource MaterialDesignCircularProgressBar}" IsIndeterminate="True" Visibility="Collapsed" Width="16" Height="16" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Pregătit pentru procesare."/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>