<Window x:Class="SistemAcademic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Sistem Inteligent Management Academic - v2.0" Height="700" Width="1000"
        Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Configurare Surse Date" Padding="15" Margin="0,0,0,15" BorderBrush="#D1D5DB">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <Label Content="Plan de Învățământ (Source of Truth):" FontWeight="Bold" Foreground="#374151"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowsePlan" Content="Caută..." Width="80" Click="BtnBrowsePlan_Click" DockPanel.Dock="Right" Margin="5,0,0,0"/>
                            <TextBox x:Name="TxtPlanPath" Text="Selectează plan_invatamant.pdf..." IsReadOnly="True" VerticalContentAlignment="Center" Padding="5"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <Label Content="Fișa Disciplinei (Document de analizat):" FontWeight="Bold" Foreground="#374151"/>
                        <DockPanel>
                            <Button x:Name="BtnBrowseFD" Content="Caută..." Width="80" Click="BtnBrowseFD_Click" DockPanel.Dock="Right" Margin="5,0,0,0"/>
                            <TextBox x:Name="TxtFDPath" Text="Selectează fisa_disciplina.pdf sau .docx..." IsReadOnly="True" VerticalContentAlignment="Center" Padding="5"/>
                        </DockPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="5,10,0,0">
                    <Label Content="Metodă Citire:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RadioPdfParser" Content="Parser Direct (PDF Digital/Word)" IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <RadioButton x:Name="RadioAiVision" Content="AI Vision - Llama 3.2 (Scanări/Poze)" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <UniformGrid Columns="2" Grid.Row="0" Margin="0,0,0,10">
                    <Button x:Name="BtnFastCheck" Click="BtnFastCheck_Click" Margin="0,0,5,0" Height="40" Background="#E5E7EB" BorderBrush="#9CA3AF">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡ Verificare Rapidă" FontWeight="Bold"/>
                            <TextBlock Text=" (Fără AI)" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnAiAnalysis" Click="BtnAiAnalysis_Click" Margin="5,0,0,0" Height="40" Background="#6366F1" Foreground="White" BorderThickness="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧠 Analiză Avansată" FontWeight="Bold"/>
                            <TextBlock Text=" (Gemma 3)" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <GroupBox Header="Raport de Integritate și Conformitate" Grid.Row="1">
                    <ListBox x:Name="ErrorsListBox" BorderThickness="0" Background="Transparent" Padding="5">
                    </ListBox>
                </GroupBox>

                <Button x:Name="BtnExportSyllabus" Grid.Row="2" Content="Migrare pe Template Nou (2026)" 
                        Click="BtnExportSyllabus_Click" Height="45" Margin="0,10,0,0" 
                        Background="#10B981" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
            </Grid>

            <GroupBox Header="Gemma 3 AI Copilot (Google API)" Grid.Column="1" BorderBrush="#6366F1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChatDisplay" Margin="10">
                                <TextBlock Text="Asistentul este gata..." Foreground="#6B7280" FontStyle="Italic"/>
                            </StackPanel>
                        </ScrollViewer>
                    </ScrollViewer>

                    <Border Grid.Row="1" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="10">
                        <DockPanel>
                            <Button x:Name="BtnSendCopilot" Content="Trimite" Click="BtnSendCopilot_Click" 
                                    DockPanel.Dock="Right" Width="70" Background="#6366F1" Foreground="White" Margin="10,0,0,0"/>
                            <TextBox x:Name="ChatInput" ToolTip="Ex: Reformulează bibliografia..." 
                                     Height="35" VerticalContentAlignment="Center" Padding="10,0"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </GroupBox>
        </Grid>

        <StatusBar Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Margin="0,15,0,0" Padding="5">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Pregătit pentru procesare." Foreground="#4B5563"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Local: Llama 3.2 Vision" Margin="0,0,15,0" FontSize="11" Foreground="#9CA3AF"/>
                    <TextBlock Text="Cloud: Gemma 3 27B" FontWeight="Bold" FontSize="11" Foreground="#6366F1"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>